{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "kafka",
  "version": "0.1.0",
  "identifier": "com.kafka.notes",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Kafka",
        "url": "index.html",
        "width": 1040,
        "height": 660,
        "minWidth": 760,
        "minHeight": 480,
        "decorations": false,
        "resizable": true,
        "skipTaskbar": true,
        "visible": true,
        "center": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage", "deb"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ]
  }
}
